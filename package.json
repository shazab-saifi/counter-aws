{
  "name": "counter-aws",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "turbo run migrate dev --filter=@repo/db",
    "db:generate": "turbo run generate --filter=@repo/db",
    "backend:build": "bun run --cwd apps/backend build",
    "backend:start": "bun run db:migrate && bun run --cwd apps/backend start",
    "frontend:build": "bun run --cwd apps/frontend build",
    "frontend:start": "bun run --cwd apps/frontend start"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
